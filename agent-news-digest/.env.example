# Gmail delivery — copy to .env and fill in your values
# GMAIL_SENDER and GMAIL_RECIPIENT can be the same address.
# GMAIL_APP_PASSWORD must be a Google App Password (not your account password).
# How to create one: https://support.google.com/accounts/answer/185833
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_RECIPIENT=you@gmail.com

# Optional: override the Gemini model (default: gemini-flash-latest)
# MODEL=gemini-2.0-flash-001
